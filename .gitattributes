# Normalize line endings. Shell scripts and Linux service/unit files MUST be LF -
# a CRLF `#!/usr/bin/env bash\r` shebang fails on the VPS ("bad interpreter").
*.sh            text eol=lf
*.service       text eol=lf
*.sql           text eol=lf
*.env.example   text eol=lf
Caddyfile       text eol=lf
Dockerfile      text eol=lf
*.Dockerfile    text eol=lf
