# ============================================================================
# AIOS Docker stack — environment TEMPLATE (safe to commit; placeholders only).
# Copy to the repo-root `.env` (git-ignored) and fill in, OR paste into the
# Portainer stack "Environment variables" panel. See DEPLOY-PORTAINER.md.
#
# Generate the crypto values:
#   EdDSA keypair + vault key:
#     python - <<'PY'
#     import os,base64
#     from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey as E
#     from cryptography.hazmat.primitives import serialization as s
#     k=E.generate()
#     pr=k.private_bytes(s.Encoding.PEM,s.PrivateFormat.PKCS8,s.NoEncryption()).decode()
#     pu=k.public_key().public_bytes(s.Encoding.PEM,s.PublicFormat.SubjectPublicKeyInfo).decode()
#     print('JWT_PRIVATE_KEY='+pr.replace(chr(10),'\\n'))
#     print('JWT_PUBLIC_KEY='+pu.replace(chr(10),'\\n'))
#     print('VAULT_MASTER_KEY='+base64.b64encode(os.urandom(32)).decode())
#     PY
#   DB passwords:  python -c "import secrets;print(secrets.token_hex(16))"   (x3)
# ============================================================================

TAG=local
WEB_PORT=3000
API_PORT=8000

# --- REQUIRED: Postgres + the two RLS role passwords (hex, URL-safe) ---------
POSTGRES_PASSWORD=change_me_superuser
AUTH_DB_PASSWORD=change_me_authenticated
SERVICE_DB_PASSWORD=change_me_service_role

# --- REQUIRED: local auth + vault -------------------------------------------
JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...replace-me...\n-----END PRIVATE KEY-----\n
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...replace-me...\n-----END PUBLIC KEY-----\n
VAULT_MASTER_KEY=change_me_base64_32_bytes

# --- REQUIRED: seed owner (first login) -------------------------------------
SEED_OWNER_USERNAME=owner
SEED_OWNER_PASSWORD=change_me_strong
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_NAME=Agency Owner

# --- Hosts / CORS (narrow to real hosts in production) ----------------------
API_CORS_ORIGINS=*
TRUSTED_HOSTS=*
LOG_LEVEL=INFO

# --- OPTIONAL provider keys (module degrades to a fake when blank) ----------
SERPER_API_KEY=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SUMMARY=claude-haiku-4-5
ANTHROPIC_MODEL_HEAVY=claude-sonnet-5
RESEND_API_KEY=
RESEND_FROM_EMAIL=AIOS <notifications@example.com>
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=
# Content article images (OpenAI-compatible). Blank key = images degrade to placeholder.
IMAGE_GEN_API_KEY=
IMAGE_GEN_MODEL=gpt-image-1
# Off-page citation-builder direct submitters (blank = that submitter skipped).
# Apify is the fallback engine; it needs BOTH the token AND an actor id to switch on.
FOURSQUARE_API_KEY=
BING_PLACES_API_KEY=
APIFY_API_TOKEN=
APIFY_CITATION_ACTOR_ID=
SENTRY_DSN=
