# AIOS backend environment.
# Copy this file to .env (which is gitignored) and fill in the values.
# Every value here is read by app/config.py. Optional values degrade gracefully in
# dev (the app still boots); required secrets are enforced only when APP_ENV=prod.

# --- App -------------------------------------------------------------------
APP_ENV=dev                              # dev | prod  (drives docs, CORS, log format, fail-fast)
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
API_CORS_ORIGINS=http://localhost:3000   # comma-separated origins allowed to call the API (the Next.js app)
TRUSTED_HOSTS=*                           # comma-separated allowed Host headers; * allows any (set real hosts in prod)

# --- Supabase (server-side) ------------------------------------------------
# NOTE: the service_role key BYPASSES Row-Level Security. It is server-only:
# never send it to a browser, never log it, never put it in the frontend bundle.
SUPABASE_URL=                            # e.g. https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=               # admin key (server-only)
SUPABASE_ANON_KEY=                       # public/anon key (used with a user JWT for RLS-respecting calls)

# Postgres connection string - used ONLY by tooling (db/migrations apply + the
# RLS gate + Supabase integration tests), never by the running API. Supabase:
# Project Settings -> Database -> Connection string (use the pooler for CI).
DATABASE_URL=                            # e.g. postgresql://postgres:...@db.xxxx.supabase.co:5432/postgres

# --- Auth (JWT verification) -----------------------------------------------
# Supabase signs access tokens with asymmetric keys; the API verifies them
# against the project JWKS (derived from SUPABASE_URL). No shared secret needed.
SUPABASE_JWT_AUD=authenticated           # expected token audience
SUPABASE_JWKS_URL=                        # optional override; default: <SUPABASE_URL>/auth/v1/.well-known/jwks.json

# --- Redis (app cache + readiness) -----------------------------------------
# Separate logical DBs: app cache on /0, Celery broker on /1, results on /2,
# so a cache flush can never wipe queued jobs. docker-compose overrides the host to `redis`.
REDIS_URL=redis://localhost:6379/0            # app cache + readiness ping
CELERY_BROKER_URL=redis://localhost:6379/1    # Celery job queue
CELERY_RESULT_BACKEND=redis://localhost:6379/2 # Celery task results

# --- Audit engine (Module 01) ----------------------------------------------
# The SEO audit engine (../danyals-audit-system) is a SEPARATE Python product
# with its OWN dependencies (playwright, etc.). The worker invokes it as an
# external subprocess using ITS OWN interpreter - it is never imported into this
# venv. Leave these blank in dev: the unit suite mocks the subprocess, and the
# live integration test auto-skips when AUDIT_ENGINE_DIR is unset.
AUDIT_ENGINE_DIR=                        # repo root of danyals-audit-system (e.g. ../danyals-audit-system)
AUDIT_ENGINE_PYTHON=                     # interpreter in that repo's venv (e.g. ../danyals-audit-system/.venv/Scripts/python.exe)
AUDIT_TIMEOUT_SECONDS=1500               # worker-owned hard timeout per run (< Celery task_time_limit 1800)
AUDIT_MAX_PAGES=100                      # default crawl breadth (--max-pages)
AUDIT_PROFILE=general                    # engine --profile
AUDIT_PAID_COST_ESTIMATE=1.5             # engine reports no spend; a Paid run logs this via the cost path

# --- Tuning ----------------------------------------------------------------
READINESS_TIMEOUT_SECONDS=3              # hard ceiling for each /health/ready dependency check

# --- Sentry (optional) -----------------------------------------------------
SENTRY_DSN=                              # leave blank to disable error reporting
