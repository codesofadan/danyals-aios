# AIOS backend - PRODUCTION environment template.
#
# Copy to /etc/aios/aios.env (0600 root:root), then fill it in. install.sh seeds
# this file on its first run and stops so you can edit it. systemd loads it as
# EnvironmentFile for aios-api / aios-worker / aios-beat; pydantic-settings then
# reads these from the process environment (env vars win over any stray .env).
#
# ============================ FOOTGUN (read this) ============================
# systemd EnvironmentFile does NOT strip a trailing inline `# comment` from a
# value line - `KEY=value  # note` would set KEY to "value  # note". So EVERY
# comment in this file lives on its OWN line, never after a value. Keep it that
# way when you edit. (This also sidesteps the python-dotenv blank-value footgun.)
# Multi-line PEM values are stored as ONE double-quoted line with newlines as
# literal \n; systemd un-escapes them and the app's config also restores them.
# ============================================================================

# --- App -------------------------------------------------------------------
# dev | prod. prod: docs off, JSON logs, fail-fast on any missing REQUIRED secret.
APP_ENV=prod
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
# comma-separated origins allowed to call the API (your real dashboard host).
API_CORS_ORIGINS=https://app.example.com
# comma-separated allowed Host headers (TrustedHostMiddleware). Set your real host.
TRUSTED_HOSTS=api.example.com

# ===================== REQUIRED IN PROD (app won't boot without these) =======

# --- Local Postgres (the data plane) - two DSNs, one per trust level --------
# Both target the loopback PostgreSQL 16 `aios` DB. install.sh sets each role's
# password FROM these DSNs, so pick strong URL-safe passwords here first.
# The password sits inside a URI, so use alphanumerics (or percent-encode any
# reserved char: @ -> %40, : -> %3A, / -> %2F, # -> %23). Avoid ${...} and $ (both
# systemd and libpq treat the DSN literally, but a stray ${VAR} confuses tooling).
# authenticated-role DSN -> the per-request RLS pool (RLS APPLIES). Also used by
# db migrations apply + the RLS gate.
DATABASE_URL=postgresql://authenticated:CHANGE_ME_AUTH_PW@127.0.0.1:5432/aios
# service_role DSN -> the privileged pool (BYPASSRLS); server-only, never logged.
DATABASE_ADMIN_URL=postgresql://service_role:CHANGE_ME_SERVICE_PW@127.0.0.1:5432/aios

# --- Local auth (own EdDSA / Ed25519 JWT) ----------------------------------
# Login SIGNS a short-lived access token with the PRIVATE key; every request
# VERIFIES with the PUBLIC key under a hard ["EdDSA"] allow-list. No JWKS, no
# shared secret. Generate a fresh keypair (prints both lines ready to paste):
#   python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey as E; from cryptography.hazmat.primitives import serialization as s; k=E.generate(); pr=k.private_bytes(s.Encoding.PEM,s.PrivateFormat.PKCS8,s.NoEncryption()).decode(); pu=k.public_key().public_bytes(s.Encoding.PEM,s.PublicFormat.SubjectPublicKeyInfo).decode(); print('JWT_PRIVATE_KEY=\"'+pr.replace(chr(10),'\\\\n')+'\"'); print('JWT_PUBLIC_KEY=\"'+pu.replace(chr(10),'\\\\n')+'\"')"
# API-only; NEVER commit the real key or expose it to the frontend.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...replace-me...\n-----END PRIVATE KEY-----\n"
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...replace-me...\n-----END PUBLIC KEY-----\n"
# expected `iss` on our own tokens
LOCAL_JWT_ISSUER=aios
# expected `aud` on our own tokens
JWT_AUDIENCE=authenticated
# access-token lifetime (seconds)
JWT_ACCESS_TTL_SECONDS=3600

# --- Vault (app-layer AES-256-GCM) -----------------------------------------
# base64-encoded 32-byte master key; lives ONLY here, NEVER in Postgres. Rotating
# it means RE-SEALING every stored secret; losing it makes them unrecoverable.
# Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
VAULT_MASTER_KEY=CHANGE_ME_BASE64_32_BYTES

# ===================== OPERATIONAL (sane defaults; adjust as needed) =========

# --- Redis (app cache + readiness) and Celery (separate logical DBs) --------
# INVARIANT #7: app cache on /0, Celery broker on /1, results on /2, so a cache
# FLUSHDB can never wipe queued jobs.
REDIS_URL=redis://127.0.0.1:6379/0
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/2

# --- Seed owner (first login; used once by install.sh, then inert) ----------
# provision_owner mints the first OWNER (super template = all features) from these.
# Idempotent. Keep the password strong; it is never logged.
SEED_OWNER_USERNAME=owner
SEED_OWNER_PASSWORD=CHANGE_ME_OWNER_PASSWORD
SEED_OWNER_EMAIL=owner@example.com
SEED_OWNER_NAME=Agency Owner

# --- Tuning ----------------------------------------------------------------
# hard per-dependency ceiling for /health/ready
READINESS_TIMEOUT_SECONDS=3

# ===================== OPTIONAL PROVIDER KEYS (key-gated modules) ============
# Every block below is OPTIONAL: the module ships + unit-tests on deterministic
# fakes and ACTIVATES when its key lands (a keyless deploy degrades gracefully,
# it never crashes). Fill a block only when you have that provider's credential.

# --- Audit engine (Module 01) - a SEPARATE product, its OWN interpreter -----
# repo root of danyals-audit-system (subprocess, never imported here)
AUDIT_ENGINE_DIR=
# interpreter inside that repo's venv
AUDIT_ENGINE_PYTHON=
# worker-owned hard timeout per run (< the Celery task_time_limit of 1800)
AUDIT_TIMEOUT_SECONDS=1500
AUDIT_MAX_PAGES=100
AUDIT_PROFILE=general
# engine reports no spend; a Paid run logs this estimate via the cost path
AUDIT_PAID_COST_ESTIMATE=1.5
# controlled root for stored report PDFs + findings.json (keep under /var/lib/aios
# so the worker's StateDirectory covers it); blank = downloads disabled
AUDIT_ARTIFACT_DIR=/var/lib/aios/artifacts/audits
# Fiverr upsell link on the PUBLIC free-audit report (not a secret)
FIVERR_UPSELL_URL=https://www.fiverr.com/iamdaani

# --- Context / AI-memory (P6B): Anthropic summarizer + Voyage embedder + Pinecone
# Anthropic (summarizer). Anthropic has NO embeddings API - the embedder is separate.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_SUMMARY=claude-haiku-4-5
ANTHROPIC_MODEL_HEAVY=claude-sonnet-5
# Embedder (Voyage AI). EMBEDDINGS_DIM MUST match the Pinecone index dimension.
EMBEDDINGS_PROVIDER=voyage
EMBEDDINGS_API_KEY=
EMBEDDINGS_MODEL=voyage-3
EMBEDDINGS_DIM=1024
# Vector store (Pinecone; namespaced per entity). Index dim MUST equal EMBEDDINGS_DIM.
PINECONE_API_KEY=
PINECONE_INDEX=
# optional index host override (blank -> resolved by name)
PINECONE_HOST=
CONTEXT_DEBOUNCE_SECONDS=30
CONTEXT_SUMMARY_TOKEN_BUDGET=1200
CONTEXT_TOPK=6
CONTEXT_MAX_FACTS=64
CONTEXT_BACKOFF_SECONDS=300
CONTEXT_DISPATCH_BATCH=100
# reconcile sweep cadence (seconds); safety net, runs rarely
CONTEXT_RECONCILE_SECONDS=3600
# turn the reconcile sweep from a detector into a self-healer (default off)
CONTEXT_RECONCILE_REPAIR=false
CONTEXT_SUMMARIZE_COST_ESTIMATE=0.02
CONTEXT_EMBED_COST_ESTIMATE=0.001
# NOTE: the context provider SDKs are the [ai] extra - install them on the box
# once these keys land:  sudo -u aios /opt/aios/backend/.venv/bin/pip install -e '.[ai]'

# --- Content module (P7A): Serper SERP research + image generation ----------
SERPER_API_KEY=
IMAGE_GEN_API_KEY=
IMAGE_GEN_MODEL=gpt-image-1
CONTENT_RESEARCH_COST_ESTIMATE=0.01
CONTENT_GENERATE_COST_ESTIMATE=0.15
CONTENT_RESEARCH_NEUTRAL_DA=30.0
CONTENT_RESEARCH_WINNABLE_STRETCH=15.0
CONTENT_RESEARCH_CACHE_TTL_SECONDS=86400
CONTENT_TEARDOWN_TIMEOUT_SECONDS=8.0
CONTENT_TEARDOWN_MAX_PAGES=10
# controlled root for rendered content deliverables (keep under /var/lib/aios);
# blank -> falls back to AUDIT_ARTIFACT_DIR
CONTENT_ARTIFACT_DIR=/var/lib/aios/artifacts/content
CONTENT_PRECHECK_RESEARCH_CALLS=10
CONTENT_PRECHECK_WRITER_CALLS=14

# --- Off-page module (7B): DataForSEO backlinks + BrightLocal citations ------
# DataForSEO uses HTTP Basic (login + password). Login is not a secret.
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=
BRIGHTLOCAL_API_KEY=
WEB2_PUBLISH_COST_ESTIMATE=0.0
OFFPAGE_MONITOR_COST_ESTIMATE=0.05

# --- Reports (7D): the Google Sheets operational store ----------------------
# Full service-account credential JSON (carries a private key). Buffered in Redis
# until this lands.
GOOGLE_SHEETS_SA_JSON=

# --- Delivery (7F): transactional email (Resend) + Slack --------------------
# In-app notifications + alert rows persist without these; only the email/Slack
# legs are skipped until the keys arrive.
RESEND_API_KEY=
# verified Resend sender (not a secret)
RESEND_FROM_EMAIL=AIOS <notifications@example.com>
# Slack incoming-webhook URL (embeds a token)
SLACK_WEBHOOK_URL=

# --- Backups (7G): pg_dump snapshots + guarded restore + optional B2 offsite -
# controlled root snapshots are written under (keep under /var/lib/aios so the
# worker's StateDirectory covers it); blank -> a run degrades to a 'failed' record
BACKUP_ARTIFACT_DIR=/var/lib/aios/backups
# pg_dump / pg_restore binaries (postgresql-16 installs them on PATH)
PG_DUMP_BIN=pg_dump
PG_RESTORE_BIN=pg_restore
BACKUP_TIMEOUT_SECONDS=1800
# Backblaze B2 offsite (S3-compatible). KEY-GATED on the full triple; without all
# three the local snapshot still succeeds and only the offsite copy is skipped.
# key_id is a login-style id (not a secret); the application_key IS a secret.
B2_KEY_ID=
B2_APPLICATION_KEY=
B2_BUCKET=
# optional S3 endpoint override (region host)
B2_ENDPOINT_URL=

# --- Sentry (optional error reporting) -------------------------------------
# blank -> disabled
SENTRY_DSN=
