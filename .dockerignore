# Root build context is used by backend/Dockerfile (it needs backend/ + db/migrations/).
# Keep the context small + free of secrets and unrelated trees.

# VCS / editor
.git
.gitignore
.github
**/.DS_Store
**/Thumbs.db

# Frontend + its stray duplicate (backend image never needs these)
frontend
daniyals-frontend
**/node_modules
**/.next

# Sibling trees the backend image never needs (keep the root context lean + fast).
# NOTE: danyals-audit-system IS now built into the image (the worker subprocess-invokes
# it as the audit engine), so it is NO LONGER excluded wholesale — only its heavy /
# unneeded subtrees are dropped from the context below.
danyals-audit-system/data
danyals-audit-system/generated-audits
danyals-audit-system/tests
danyals-audit-system/docs
aios
aios-skills
.claude
.claude-plugin

# Python caches / local venvs / build artifacts
**/__pycache__
**/*.pyc
**/.venv
**/.mypy_cache
**/.ruff_cache
**/.pytest_cache
**/*.egg-info
**/dist
**/build

# Secrets / local env (NEVER bake these into an image)
**/.env
**/.env.*
!**/.env.example
!**/.env.docker.example

# Docs / design / deliverables (not needed at runtime)
design
docs
context/*.pdf

# Docker meta itself
**/Dockerfile
docker-compose*.yml
