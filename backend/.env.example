# AIOS backend environment.
# Copy this file to .env (which is gitignored) and fill in the values.
# Every value here is read by app/config.py. Optional values degrade gracefully in
# dev (the app still boots); required secrets are enforced only when APP_ENV=prod.
#
# FOOTGUN: python-dotenv treats an inline `# comment` on a BLANK-value line as the
# value itself (e.g. `SENTRY_DSN=   # off` sets SENTRY_DSN to "# off", not ""). So
# every key that ships blank keeps its comment on its OWN line ABOVE the key. Keys
# that ship with a real value may keep a trailing inline comment (dotenv strips it).

# --- App -------------------------------------------------------------------
APP_ENV=dev                              # dev | prod  (drives docs, CORS, log format, fail-fast)
LOG_LEVEL=INFO                           # DEBUG | INFO | WARNING | ERROR
API_CORS_ORIGINS=http://localhost:3000   # comma-separated origins allowed to call the API (the Next.js app)
TRUSTED_HOSTS=*                           # comma-separated allowed Host headers; * allows any (set real hosts in prod)

# --- Supabase (server-side) ------------------------------------------------
# NOTE: the service_role key BYPASSES Row-Level Security. It is server-only:
# never send it to a browser, never log it, never put it in the frontend bundle.
# e.g. https://xxxx.supabase.co
SUPABASE_URL=
# admin key (server-only)
SUPABASE_SERVICE_ROLE_KEY=
# public/anon key (used with a user JWT for RLS-respecting calls)
SUPABASE_ANON_KEY=

# Postgres connection string - today used ONLY by tooling (db/migrations apply +
# the RLS gate + Supabase integration tests), never by the running API. Supabase:
# Project Settings -> Database -> Connection string (use the pooler for CI).
# During the P6A migration this same var also feeds config.database_url (the local
# authenticated-role RLS DSN). e.g. postgresql://postgres:...@db.xxxx.supabase.co:5432/postgres
DATABASE_URL=

# --- Auth (JWT verification) -----------------------------------------------
# Supabase signs access tokens with asymmetric keys; the API verifies them
# against the project JWKS (derived from SUPABASE_URL). No shared secret needed.
SUPABASE_JWT_AUD=authenticated           # expected token audience
# optional override; default: <SUPABASE_URL>/auth/v1/.well-known/jwks.json
SUPABASE_JWKS_URL=

# --- Local Postgres (P6A migration; ADDITIVE) ------------------------------
# These sit ALONGSIDE the Supabase config during the dual-config window and are
# OPTIONAL until the cutover (P6A-8) makes them required in prod. Nothing below
# is wired into the running app yet. NOTE (dotenv footgun): every blank-value key
# keeps its comment on its OWN line ABOVE the key, never trailing an empty value.
#
# Authenticated-role DSN -> the per-request RLS connection pool (RLS applies).
# NOTE: this is the SAME env var as DATABASE_URL above (config.database_url reads
# it). Today it holds the Supabase tooling DSN; at cutover it becomes the local
# authenticated-role connection. e.g. postgresql://authenticated:...@localhost:5432/aios
#
# service_role DSN -> the privileged pool (BYPASSRLS); server-only, never logged.
# e.g. postgresql://service_role:...@localhost:5432/aios
DATABASE_ADMIN_URL=

# --- Local auth (own EdDSA JWT; replaces networked JWKS at cutover) ---------
# Login SIGNS an access token with the Ed25519 PRIVATE key; the API VERIFIES every
# token with the PUBLIC key (algorithm allow-list ["EdDSA"] only -> no alg-confusion).
# STORAGE: each PEM is stored as ONE double-quoted line with real newlines escaped
# as literal \n. config.jwt_{private,public}_key_pem restores the newlines in code
# (a no-op if the value already has them), so PyJWT gets valid multi-line PEM.
# Generate a keypair (writes the PRIVATE key hidden; prints only the PUBLIC key):
#   python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey as E; from cryptography.hazmat.primitives import serialization as s; k=E.generate(); pr=k.private_bytes(s.Encoding.PEM,s.PrivateFormat.PKCS8,s.NoEncryption()).decode(); pu=k.public_key().public_bytes(s.Encoding.PEM,s.PublicFormat.SubjectPublicKeyInfo).decode(); print('JWT_PRIVATE_KEY=\"'+pr.replace(chr(10),'\\\\n')+'\"'); print('JWT_PUBLIC_KEY=\"'+pu.replace(chr(10),'\\\\n')+'\"')"
# API-only; keep off the frontend and out of logs. NEVER commit the real key.
JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...replace-me...\n-----END PRIVATE KEY-----\n"
# Ed25519 PEM public key (VERIFIES access tokens).
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...replace-me...\n-----END PUBLIC KEY-----\n"
LOCAL_JWT_ISSUER=aios                     # expected `iss` on our own EdDSA tokens
JWT_AUDIENCE=authenticated               # expected `aud` on our own EdDSA tokens
JWT_ACCESS_TTL_SECONDS=3600              # access-token lifetime (seconds)

# --- Seed owner (dev/test bootstrap ONLY) ----------------------------------
# `python -m app.cli.provision_owner` mints the first local OWNER from these so
# the app + integration tests have a login. Not a prod path; the password is a
# secret (never logged). Leave blank in prod.
SEED_OWNER_USERNAME=
SEED_OWNER_PASSWORD=
SEED_OWNER_EMAIL=owner@local.aios
SEED_OWNER_NAME=AIOS Owner

# --- Vault (app-layer AES-256-GCM; replaces Supabase Vault at cutover) ------
# base64-encoded 32-byte AES-256-GCM master key; held ONLY in env, NEVER in
# Postgres. Generate: python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# ROTATING this key requires RE-SEALING every existing secret (decrypt with the
# old key, re-encrypt with the new one, bump key_version) -- vault_keys.key_version
# supports staging that migration. Losing the key makes stored secrets unrecoverable.
VAULT_MASTER_KEY=

# --- Redis (app cache + readiness) -----------------------------------------
# Separate logical DBs: app cache on /0, Celery broker on /1, results on /2,
# so a cache flush can never wipe queued jobs.
REDIS_URL=redis://localhost:6379/0            # app cache + readiness ping
CELERY_BROKER_URL=redis://localhost:6379/1    # Celery job queue
CELERY_RESULT_BACKEND=redis://localhost:6379/2 # Celery task results

# --- Audit engine (Module 01) ----------------------------------------------
# The SEO audit engine (../danyals-audit-system) is a SEPARATE Python product
# with its OWN dependencies (playwright, etc.). The worker invokes it as an
# external subprocess using ITS OWN interpreter - it is never imported into this
# venv. Leave these blank in dev: the unit suite mocks the subprocess, and the
# live integration test auto-skips when AUDIT_ENGINE_DIR is unset.
# repo root of danyals-audit-system (e.g. ../danyals-audit-system)
AUDIT_ENGINE_DIR=
# interpreter in that repo's venv (e.g. ../danyals-audit-system/.venv/Scripts/python.exe)
AUDIT_ENGINE_PYTHON=
AUDIT_TIMEOUT_SECONDS=1500               # worker-owned hard timeout per run (< Celery task_time_limit 1800)
AUDIT_MAX_PAGES=100                      # default crawl breadth (--max-pages)
AUDIT_PROFILE=general                    # engine --profile
AUDIT_PAID_COST_ESTIMATE=1.5             # engine reports no spend; a Paid run logs this via the cost path
# controlled root for stored report PDFs + findings.json (API + worker share it); blank = no downloads
AUDIT_ARTIFACT_DIR=

# --- Tuning ----------------------------------------------------------------
READINESS_TIMEOUT_SECONDS=3              # hard ceiling for each /health/ready dependency check

# --- Sentry (optional) -----------------------------------------------------
# leave blank to disable error reporting
SENTRY_DSN=
